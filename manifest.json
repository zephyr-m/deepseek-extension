{
  "manifest_version": 3,
  "name": "DeepSeek Console Bridge",
  "version": "0.2.0",
  "description": "Tiny console bridge for the DeepSeek web UI.",
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://*.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-api.js"],
      "matches": [
        "https://chat.deepseek.com/*",
        "https://*.deepseek.com/*"
      ]
    }
  ]
}
